terraform {
  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 3.80"
    }
  }
  required_version = ">= 1.5.0"
}

provider "azurerm" {
  features {}
}

# ??????????????????????????????????????????????
# Locals — central naming
# ??????????????????????????????????????????????
locals {
  base_name            = "invostaq-${var.environment}"
  storage_account_name = "invostaq${var.environment}sa"
  sql_server_name      = "invostaq-${var.environment}-sql"
  sql_db_name          = "InvoStaqDb"
  app_service_plan     = "invostaq-${var.environment}-asp"
  function_app_name    = "invostaq-${var.environment}-func"
  app_insights_name    = "invostaq-${var.environment}-ai"
}

# ??????????????????????????????????????????????
# Resource Group
# ??????????????????????????????????????????????
resource "azurerm_resource_group" "rg" {
  name     = "rg-${local.base_name}"
  location = var.location
}

# ??????????????????????????????????????????????
# Storage Account
# ??????????????????????????????????????????????
resource "azurerm_storage_account" "sa" {
  name                     = local.storage_account_name
  resource_group_name      = azurerm_resource_group.rg.name
  location                 = azurerm_resource_group.rg.location
  account_tier             = "Standard"
  account_replication_type = "LRS"
  min_tls_version          = "TLS1_2"
}

# ??????????????????????????????????????????????
# Application Insights
# ??????????????????????????????????????????????
resource "azurerm_application_insights" "ai" {
  name                = local.app_insights_name
  location            = azurerm_resource_group.rg.location
  resource_group_name = azurerm_resource_group.rg.name
  application_type    = "web"
  retention_in_days   = 30
}

# ??????????????????????????????????????????????
# Azure SQL Server
# ??????????????????????????????????????????????
resource "azurerm_mssql_server" "sql" {
  name                         = local.sql_server_name
  resource_group_name          = azurerm_resource_group.rg.name
  location                     = azurerm_resource_group.rg.location
  version                      = "12.0"
  administrator_login          = var.sql_admin_login
  administrator_login_password = var.sql_admin_password
  minimum_tls_version          = "1.2"
}

# Allow Azure services through firewall
resource "azurerm_mssql_firewall_rule" "allow_azure" {
  name             = "AllowAzureServices"
  server_id        = azurerm_mssql_server.sql.id
  start_ip_address = "0.0.0.0"
  end_ip_address   = "0.0.0.0"
}

# ??????????????????????????????????????????????
# Azure SQL Database
# ??????????????????????????????????????????????
resource "azurerm_mssql_database" "db" {
  name         = local.sql_db_name
  server_id    = azurerm_mssql_server.sql.id
  collation    = "SQL_Latin1_General_CP1_CI_AS"
  sku_name     = "Basic"
  max_size_gb  = 2
}

# ??????????????????????????????????????????????
# App Service Plan (Consumption - Serverless)
# ??????????????????????????????????????????????
resource "azurerm_service_plan" "asp" {
  name                = local.app_service_plan
  location            = azurerm_resource_group.rg.location
  resource_group_name = azurerm_resource_group.rg.name
  os_type             = "Windows"
  sku_name            = "Y1"
}

# ??????????????????????????????????????????????
# Azure Function App
# ??????????????????????????????????????????????
resource "azurerm_windows_function_app" "func" {
  name                       = local.function_app_name
  location                   = azurerm_resource_group.rg.location
  resource_group_name        = azurerm_resource_group.rg.name
  service_plan_id            = azurerm_service_plan.asp.id
  storage_account_name       = azurerm_storage_account.sa.name
  storage_account_access_key = azurerm_storage_account.sa.primary_access_key
  https_only                 = true

  site_config {
    application_stack {
      dotnet_version              = "v8.0"
      use_dotnet_isolated_runtime = true
    }
    minimum_tls_version = "1.2"
  }

  app_settings = {
    "FUNCTIONS_EXTENSION_VERSION"    = "~4"
    "APPINSIGHTS_INSTRUMENTATIONKEY" = azurerm_application_insights.ai.instrumentation_key
    "SqlConnectionString"            = "Server=tcp:${azurerm_mssql_server.sql.fully_qualified_domain_name},1433;Initial Catalog=${local.sql_db_name};User ID=${var.sql_admin_login};Password=${var.sql_admin_password};Encrypt=True;TrustServerCertificate=False;"
  }

  depends_on = [
    azurerm_storage_account.sa,
    azurerm_application_insights.ai,
    azurerm_mssql_database.db
  ]
}